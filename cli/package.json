{
  "name": "@flabbergasted-ai/skills",
  "version": "0.1.1",
  "description": "CLI tool for searching, installing, and managing AI agent skills",
  "type": "module",
  "bin": {
    "skills": "./bin/skills.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flabbergasted-ai/skills.git"
  },
  "author": "Flabbergasted AI",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "build-index": "tsx src/build-index.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "ai",
    "skills",
    "claude",
    "cursor",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "ora": "^8.2.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
